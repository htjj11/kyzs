# ============================================================
#  kyzs 科研助手后端 - 环境变量配置模板
#  使用方法：复制此文件为 .env，填入真实值后启动
#  cp .env.example .env
# ============================================================

# ── 数据库（MySQL）────────────────────────────────────────────
SQL_IP=127.0.0.1
SQL_PORT=3306
SQL_USER=root
SQL_PASSWORD=your_db_password_here
SQL_DATABASE=kyzs

# ── AI 大模型（SiliconFlow / DeepSeek-V3）────────────────────
# 获取地址：https://siliconflow.cn → 控制台 → API Key
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 讯飞星火（联网搜索）──────────────────────────────────────
# 格式：APIKey:APISecret（在讯飞开放平台获取）
# 获取地址：https://console.xfyun.cn
XUNFEI_API_KEY=xxxxxxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 重庆聚合文献检索────────────────────────────────────────────
JUHE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AnythingLLM（本地向量知识库）──────────────────────────────
# 启动 AnythingLLM 后在 设置 → API Key 中获取
ANYTHINGLLM_BASE_URL=http://localhost:3001
ANYTHINGLLM_API_KEY=XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX
ANYTHINGLLM_WORKSPACE=kyzs
